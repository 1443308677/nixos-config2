# ============================================
# 系统软件包配置模块
# 配置全局安装的系统软件包和 Shell 环境
# ============================================

{ config, pkgs, ... }:

{
  # ------------------------------
  # 系统级软件包
  # ------------------------------
  environment.systemPackages = with pkgs; [
    wget           # 命令行下载工具
    git            # 版本控制工具
    curl           # 命令行 HTTP 客户端
    fastfetch      # 系统信息展示工具（类似 neofetch）
    nautilus       # GNOME 文件管理器
  ];

  # ------------------------------
  # Shell 环境配置
  # ------------------------------
  environment.shells = [ pkgs.bash pkgs.fish ];  # 允许的 Shell 列表

  # ------------------------------
  # 程序配置
  # ------------------------------
  programs.firefox.enable = true;  # 启用系统级 Firefox 配置
}
